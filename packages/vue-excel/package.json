{
  "name": "@vue-office-plus/excel",
  "version": "0.1.0",
  "description": "Vue3 Excel文档预览组件",
  "main": "lib/vue-office-excel.umd.js",
  "module": "lib/vue-office-excel.mjs",
  "types": "lib/index.d.ts",
  "style": "lib/style.css",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": "./lib/vue-office-excel.mjs",
      "require": "./lib/vue-office-excel.umd.js",
      "types": "./lib/index.d.ts"
    },
    "./style.css": "./lib/style.css",
    "./lib/*": "./lib/*"
  },
  "files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf lib",
    "build": "npm run clean && vite build"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "tinycolor2": "^1.6.0",
    "dayjs": "^1.11.10",
    "lodash": "^4.17.21",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-vue": "^5.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vue": "^3.3.8"
  },
  "keywords": [
    "vue",
    "vue3",
    "excel",
    "xlsx",
    "preview",
    "预览"
  ],
  "author": "Dylan <1057626658@qq.com>",
  "license": "MIT",
  "homepage": "https://gitee.com/dylan1201/office-preview#readme",
  "repository": {
    "type": "git",
    "url": "git+https://gitee.com/dylan1201/office-preview.git",
    "directory": "packages/vue-excel"
  },
  "bugs": {
    "url": "https://gitee.com/dylan1201/office-preview/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
