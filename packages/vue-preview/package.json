{
  "name": "vue3-office-preview",
  "version": "0.1.2",
  "description": "Vue3 Office 文档预览聚合包 - 一站式预览 Word/Excel/PPT",
  "main": "lib/vue-office-preview.umd.js",
  "module": "lib/vue-office-preview.mjs",
  "types": "lib/index.d.ts",
  "style": "lib/style.css",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": "./lib/vue-office-preview.mjs",
      "require": "./lib/vue-office-preview.umd.js",
      "types": "./lib/index.d.ts"
    },
    "./style.css": "./lib/style.css",
    "./lib/*": "./lib/*"
  },
  "files": [
    "lib",
    "README.md",
    "README.en.md"
  ],
  "scripts": {
    "clean": "rimraf lib",
    "build": "npm run clean && vite build"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "docx-preview": "^0.3.2",
    "exceljs": "^4.4.0",
    "tinycolor2": "^1.6.0",
    "dayjs": "^1.11.10",
    "lodash": "^4.17.21",
    "xlsx": "^0.18.5",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-vue": "^5.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vue": "^3.3.8"
  },
  "keywords": [
    "vue",
    "vue3",
    "office",
    "docx",
    "excel",
    "pptx",
    "word",
    "preview",
    "预览"
  ],
  "author": "Dylan <1057626658@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/Dylan1201/office-preview#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dylan1201/office-preview.git",
    "directory": "packages/vue-preview"
  },
  "bugs": {
    "url": "https://github.com/Dylan1201/office-preview/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
